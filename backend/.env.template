# ==========================================
# InsightStream Backend Environment Variables
# ==========================================

# ─── LLM & Search APIs ───
GEMINI_API_KEY=your_google_gemini_api_key_here
TAVILY_API_KEY=your_tavily_search_api_key_here

# ─── ChromaDB Configuration ───
# For local persistent storage:
CHROMADB_PERSIST_DIRECTORY=./chroma_data
# Or for a remote ChromaDB server:
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8000

# ─── Application Settings ───
# Set to 'production' for real deployments
ENVIRONMENT=development
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
